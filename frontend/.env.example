# ─── frontend/.env.example ───────────────────────────────────────────────────
# Copy this file to .env for local development.
# For production builds, set VITE_API_BASE_URL to your Cloud Run URL
# BEFORE running `npm run build` — Vite bakes these values into the static bundle
# at build time. They are NOT runtime environment variables.
#
# ⚠️  Do NOT prefix sensitive secrets with VITE_ — they will be visible in the
#     browser bundle. These two variables are intentionally public.
# ─────────────────────────────────────────────────────────────────────────────

# Backend Cloud Run URL — must end with /api
# Local dev:   http://localhost:3001/api
# Production:  https://YOUR_CLOUD_RUN_SERVICE_URL/api
VITE_API_BASE_URL=https://YOUR_CLOUD_RUN_SERVICE_URL/api

# Demo mode — set "true" to auto-login as guest and skip the auth screen entirely.
# Judges land directly on a pre-populated dashboard with zero clicks.
# Set "false" for normal auth flow.
VITE_DEMO_MODE=false

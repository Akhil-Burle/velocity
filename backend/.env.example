# ─── backend/.env.example ────────────────────────────────────────────────────
# Copy this file to .env for local development.
# In production (Cloud Run), set these as environment variables or Secret Manager
# references — NEVER commit a real .env file.
#
# Required secrets should be created in Secret Manager and mounted via:
#   gcloud run deploy ... --set-secrets=JWT_SECRET=velocity-jwt-secret:latest
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud Run injects PORT automatically — do not set this in Cloud Run env vars.
PORT=3001

# Production URLs — replace with real values after first deploy
BACKEND_URL=https://YOUR_CLOUD_RUN_SERVICE_URL
FRONTEND_URL=https://YOUR_FIREBASE_HOSTING_URL

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/velocity?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── Google Cloud / Vertex AI ───────────────────────────────────────────────────
# When GOOGLE_CLOUD_PROJECT is set, all Gemini calls route through Vertex AI.
# Leave blank to fall back to GEMINI_API_KEY (Gemini Developer API).
# On Cloud Run with Workload Identity, no key file is needed — just set the project.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Gemini Developer API (fallback if not using Vertex AI) ────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Google OAuth2 credentials ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include: ${BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://YOUR_CLOUD_RUN_SERVICE_URL/api/auth/google/callback

# Server-owned refresh token for Google Calendar (shared across all demo sessions).
# Run once locally: node scripts/get-google-token.js
# This token enables TWO-WAY sync: Velocity reads your Google Calendar for blocked
# slots AND pushes task focus blocks back as events (coloured by status).
# Only required for the authorized test user — demo mode works without it.
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_REFRESH_TOKEN

# Calendar write scope — must be added to your OAuth consent screen scopes:
#   https://www.googleapis.com/auth/calendar.events
# (In addition to calendar.readonly already present)

# ── Optional Google APIs ───────────────────────────────────────────────────────
# Google Cloud TTS (falls back to GEMINI_API_KEY if not set)
GOOGLE_TTS_API_KEY=YOUR_GOOGLE_TTS_API_KEY

# Google Maps Distance Matrix (optional — ETA works without it via simulation)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with 'repo' scope — creates public repos in Panic Mode
GITHUB_TOKEN=ghp_YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# ── Demo settings ─────────────────────────────────────────────────────────────
# Email address for demo Gmail sends — judges see "email sent to [this address]"
GOOGLE_DEMO_RECIPIENT=your-email@gmail.com

# Safety switch — set "true" to create drafts instead of sending real emails
EMAIL_DRAFT_ONLY=false

# Auto-seeds tasks for new guest sessions. Recommended: true for demos.
DEMO_MODE=true

# CORS: comma-separated list of allowed frontend origins (added to localhost in dev)
# Example: https://velocity-demo.web.app,https://velocity-demo.firebaseapp.com
ALLOWED_ORIGINS=https://YOUR_FIREBASE_HOSTING_URL
